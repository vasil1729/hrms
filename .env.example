# ─── Domain ───────────────────────────────────────────────
SITE_NAME=hrms.example.com

# ─── Database ─────────────────────────────────────────────
DB_NAME=hrms
DB_PASSWORD=CHANGE_ME_GENERATE_64_CHAR_HEX

# ─── Admin ────────────────────────────────────────────────
ADMIN_PASSWORD=CHANGE_ME_GENERATE_32_CHAR_PASSWORD

# ─── Frappe ───────────────────────────────────────────────
WORKERS=4
WORKER_REPLICAS=2
BACKUP_LIMIT=14

# ─── Timezone ─────────────────────────────────────────────
TZ=UTC

# ─── ERPNext Version ──────────────────────────────────────
ERPNext_VERSION=v15.41.0

# ─── External Network ─────────────────────────────────────
# Name of the Docker network your Caddy reverse proxy is on
CADDY_NETWORK=proxy
